# Required for accounts, visits, places and contact-message persistence.
# Use a durable PostgreSQL database (Neon, Supabase, Railway or equivalent).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mangystau_trails?sslmode=require&schema=public"

# Required in production. Generate a long, random value and never commit it.
AUTH_SECRET="replace-with-a-long-random-secret"

# Comma-separated account emails allowed to create places through the admin API.
ADMIN_EMAILS="admin@example.com"

# Recommended canonical production URL used by metadata, robots.txt and sitemap.xml.
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# Optional as a group. Without SMTP the form stores submissions when DATABASE_URL is set.
CONTACT_EMAIL="hello@example.com"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_SECURE="false"
SMTP_FROM="smtp-user@example.com"
