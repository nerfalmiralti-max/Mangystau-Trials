# Local development SQLite database.
# For Vercel production, use a cloud database and set DATABASE_URL in Vercel settings.
DATABASE_URL="file:./dev.db"

# Required for secure login cookies in production.
AUTH_SECRET="replace-with-a-long-random-secret"

# Server-side AI assistant. Set these in .env locally and in Vercel project settings.
AI_TIMEOUT_MS="15000"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Contact form SMTP settings. Set these in .env locally and in Vercel project settings.
CONTACT_EMAIL="hello@example.com"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_SECURE="false"
SMTP_FROM="smtp-user@example.com"
