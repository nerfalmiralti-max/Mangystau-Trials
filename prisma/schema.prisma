generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tourist {
  id           String   @id @default(cuid())
  name         String?
  country      String?
  email        String?  @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  visits         Visit[]
  savedLocations SavedLocation[]
  savedRoutes    SavedRoute[]
  reviews        Review[]
  userTrials     UserTrial[]
  userBadges     UserBadge[]
  chatMessages   ChatMessage[]
}

model Place {
  id          String  @id @default(cuid())
  name        String
  description String?
  region      String?
  category    String?
  duration    String?
  bestTime    String?
  lat         Float
  lng         Float
  image       String?
  createdAt   DateTime @default(now())

  visits  Visit[]
  reviews Review[]

  @@index([category])
}

model Visit {
  id        String   @id @default(cuid())
  touristId String
  placeId   String
  createdAt DateTime @default(now())

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)
  place   Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model SavedLocation {
  id         String   @id @default(cuid())
  touristId  String
  locationId String
  savedAt    DateTime @default(now())

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)

  @@unique([touristId, locationId])
  @@index([touristId, savedAt])
}

model SavedRoute {
  id        String   @id @default(cuid())
  touristId String
  planId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)

  @@unique([touristId, planId])
  @@index([touristId, updatedAt])
}

model Review {
  id        String   @id @default(cuid())
  touristId String
  placeId   String
  rating    Int
  title     String?
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)
  place   Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([touristId, placeId])
  @@index([placeId, createdAt])
}

model UserTrial {
  id          String   @id @default(cuid())
  touristId   String
  trialId     String
  status      String   @default("active")
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id         String   @id @default(cuid())
  touristId  String
  badgeId    String
  unlockedAt DateTime @default(now())

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  touristId  String
  role       String
  text       String
  createdAt  DateTime @default(now())

  tourist Tourist @relation(fields: [touristId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id           String   @id @default(cuid())
  name         String
  email        String
  travelWindow String?
  message      String
  status       String   @default("new")
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model ChatHistory {
  id              String   @id @default(cuid())
  sessionId       String
  clientId        String?
  role            String
  text            String
  selectedPlaceId String?
  language        String   @default("ru")
  provider        String   @default("offline")
  model           String?
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}
